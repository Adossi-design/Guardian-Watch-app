# Normalize line endings to LF in the repo; checkout as native on each OS
* text=auto eol=lf

# Dart / Flutter
*.dart text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.json text eol=lf
*.md   text eol=lf

# Android
*.kt   text eol=lf
*.java text eol=lf
*.kts  text eol=lf
*.xml  text eol=lf
*.gradle text eol=lf

# iOS / Swift
*.swift text eol=lf
*.plist text eol=lf
*.xcconfig text eol=lf

# TypeScript (Cloud Functions)
*.ts   text eol=lf

# Binary — never rewrite
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.ttf  binary
*.otf  binary
*.woff binary
*.woff2 binary
